# ==============================================
# Backend Configuration Template
# Copy this file to .env and fill in your values
# ==============================================

# Application
APP_NAME=Fullstack API
APP_VERSION=1.0.0
DEBUG=false

# Server
HOST=0.0.0.0
PORT=8000

# CORS Configuration
FRONTEND_URL=http://localhost:5173
# For multiple origins, comma-separated

# Database Configuration (PostgreSQL)
# CRITICAL: This is required if using database features
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Database Pool Settings (optional - have safe defaults)
# DB_POOL_SIZE=20
# DB_MAX_OVERFLOW=10

# Security
SECRET_KEY=change-this-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Logging
LOG_LEVEL=INFO

# Email Verification (Brevo / SendinBlue)
# Required for email verification on registration
# BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=noreply@coderblock.ai
BREVO_SENDER_NAME=Coderblock App

# AWS Configuration (optional - for cloud deployments)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret

# ==============================================
# IMPORTANT NOTES:
# - All variables with defaults are optional
# - DATABASE_URL is required if using database
# - Never commit .env file to version control
# - Use strong SECRET_KEY in production
# - BREVO_API_KEY enables email verification
# ==============================================
