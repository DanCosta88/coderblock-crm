# Frontend Environment Variables

# 🔌 API URL - Backend API endpoint
# This is automatically set during deployment!
#
# How it works:
# - Local dev: Uses fallback http://localhost:8000/api from api.ts
# - Production: Deployment creates .env.production with real backend URL
#
# Example production value (auto-generated):
# VITE_API_URL=https://cb-abc123.fly.dev/api
#
# ⚠️ DO NOT hardcode this in your code - use apiClient from services/api.ts
VITE_API_URL=http://localhost:8000/api
